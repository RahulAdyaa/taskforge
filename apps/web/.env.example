# Google OAuth Client ID (must match apps/api .env)
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# API URL — leave empty to use same-origin (production), or set for local dev
# Local dev: leave empty (defaults to http://localhost:3001/api)
# Production: leave empty (served from same domain)
VITE_API_URL=""
