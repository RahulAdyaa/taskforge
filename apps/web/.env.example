# Google OAuth Client ID (must match apps/api .env)
VITE_GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# API URL — leave empty for same-origin (Vercel production)
# Set to "http://localhost:3001/api" for local dev if not using the root `npm run dev`
# VITE_API_URL=""

# WebSocket URL — leave empty to disable real-time (uses polling instead)
# Set to "http://localhost:3001" for local dev with Socket.IO
# VITE_WS_URL=""
